# Configuración de la base de datos
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=basestire

# Configuración de JWT
JWT_SECRET=supersecret123
JWT_EXPIRATION=1h

# Configuración del Tutor Inteligente (LLM)
# Dejar OPENAI_API_KEY vacío para usar respuestas simuladas (modo desarrollo)
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_RETRY_COUNT=3

# Configuración de Redis (Obligatorio para BullMQ / Judge Engine)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Entorno Operativo (Obligatorio para TypeORM/Seguridad)
NODE_ENV=development

# Puerto del servidor
PORT=3001

# Docker Config (Para el Judge Engine)
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Logging
LOG_LEVEL=debug

# CORS Allowed Origins (Comma-separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
